<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="com.honeywell.scanneredge.permission.DECODE" />

    <!--
        Android 11+ package visibility: without this, PackageManager.getPackageInfo()
        for the Honeywell DataCollection service always throws NameNotFoundException
        even when the package is installed, causing ScannerAvailability.detect() to
        wrongly report Mode.CAMERA on real Honeywell hardware.
    -->
    <queries>
        <package android:name="com.intermec.datacollectionservice" />
    </queries>

    <application
        android:name=".RmsApplication"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RMS">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.RMS"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode_ui" />

        <!--
            Disable WorkManager's automatic androidx-startup initializer.
            On this build, its Configuration.Provider auto-detection was not
            picking up RmsApplication's Hilt-aware config — WorkManager kept
            falling back to the default reflection WorkerFactory, which
            cannot construct @HiltWorker classes (SyncWorker), so every
            enqueued sync run failed with NoSuchMethodException before ever
            reaching the network. WorkManager is initialized manually in
            RmsApplication.onCreate() instead.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>
</manifest>